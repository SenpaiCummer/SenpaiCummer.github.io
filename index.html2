<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Terms of Use</title>
    <style>
        /* CSS for the header with buttons */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #f0f0f0;
            padding: 10px 20px;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000; /* Ensure it's above other content */
        }
        .header .logo {
            font-size: 20px;
        }
        .header .buttons {
            display: flex;
            align-items: center;
        }
        .header .buttons .btn {
            margin-left: 10px;
            padding: 8px 16px;
            background-color: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }
    </style>
</head>
<body>

<!-- Header with Home and Login buttons -->
<header class="header">
    <div class="logo">Home</div>
    <div class="buttons">
        <button class="btn">Login</button>
    </div>
</header>

<!-- Your README.md content or project content -->
<div id="readmeContent">
    <!-- Replace this with your actual README.md content or project content -->
    <h1>Welcome to My Project</h1>
    <p>This is a description of my project.</p>
    <p>Here's some more information about what this project does.</p>
</div>

</body>
</html>
